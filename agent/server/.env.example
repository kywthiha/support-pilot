# Native Audio Model Configuration
# For Vertex AI (Recommended): use 'gemini-live-2.5-flash-native-audio'
# For Google AI Studio (API Key): use 'gemini-2.5-flash-native-audio-preview-12-2025'
AGENT_MODEL=gemini-live-2.5-flash-native-audio

OBSERVE_MODEL=gemini-3-flash-preview

# Vertex AI is the recommended approach.
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Google Gemini API Key (Required if GOOGLE_GENAI_USE_VERTEXAI=FALSE)
# GOOGLE_API_KEY=your_key_here